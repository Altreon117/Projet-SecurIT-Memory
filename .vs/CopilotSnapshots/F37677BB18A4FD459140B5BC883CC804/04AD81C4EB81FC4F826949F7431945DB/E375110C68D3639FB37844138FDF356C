using System;
using System.Collections.Generic;
using System.Security.Cryptography.X509Certificates;
using System.Threading;
using Random = System.Random;

namespace Memory
{
    public class Liste
    {
        public int Rows { get; set; }
        public int Columns { get; set; }
        public List<List<Carte>> Cards { get; set; }

        public List<Carte> AllCards { get; set; }


        public Liste(int numberOfPairs)
        {
            AllCards = new List<Carte>();
            Cards = new List<List<Carte>>();

            Shuffle(numberOfPairs);
        }

        public void Shuffle(int numberOfPairs)
        {
            ///initilisation des champs Rows et Columns
            Random random = new Random();
            int totalCards = numberOfPairs * 2;
            this.Rows = (int)Math.Sqrt(totalCards);
            while (this.Rows > 1 && totalCards % this.Rows != 0)
            {
                this.Rows--;
            }
            this.Columns = totalCards / this.Rows;

            ///Création de la liste mélangée des cartes avec des nombres
            List<int> numbers = new List<int>();
            for (int i = 1; i <= numberOfPairs; i++)
            {
                numbers.Add(i);
                numbers.Add(i);
            }

            // Mélange les nombres
            for (int i = numbers.Count - 1; i > 0; i--)
            {
                int randomIndex = random.Next(i + 1);
                int temp = numbers[i];
                numbers[i] = numbers[randomIndex];
                numbers[randomIndex] = temp;
            }

            for (int i = 0; i < totalCards; i++)
            {
                Carte newcarte = new Carte(i, numbers[i]);
                AllCards.Add(newcarte);
            }

            ///Création du plateau de jeu
            int index = 0;
            for (int i = 0; i < Rows; i++)
            {
                List<Carte> row = new List<Carte>();
                for (int j = 0; j < Columns; j++)
                {
                    row.Add(AllCards[index]);
                    index++;
                }
                Cards.Add(row);
            }
        }

        public void DisplayBoard()
        {
            for (int i = 0; i < Rows; i++)
            {
                for (int j = 0; j < Columns; j++)
                {
                    if (Cards[i][j].Status == Carte.State.Trouvée || Cards[i][j].Status == Carte.State.Révélée)
                    {
                        Console.Write(Cards[i][j].ImagePath + " ");
                    }
                    else
                    {
                        Console.Write("? ");
                        /// Affiche l'image de la carte pour les tests
                        ///Console.Write(Cards[i][j].ImagePath + " ");
                    }
                }
                Console.WriteLine();
            }
        }

        public void DisplayAllCards()
        {
            foreach (var card in AllCards)
            {
                Console.WriteLine($"Id: {card.Id}, ImagePath: {card.ImagePath}, State: {card.Status}");
            }
        }

        public void RevealCard(string coordinates)
        {
            string[] parts = coordinates.Split(':');
            int row = int.Parse(parts[0]);
            int column = int.Parse(parts[1]);

            Cards[row][column].Reveal();
        }

        public void HideCard(string coordinates)
        {
            string[] parts = coordinates.Split(':');
            int row = int.Parse(parts[0]);
            int column = int.Parse(parts[1]);

            Cards[row][column].Hide();
        }

        public bool IsPair(string coordinates1, string coordinates2)
        {
            string[] parts1 = coordinates1.Split(':');
            int row1 = int.Parse(parts1[0]);
            int column1 = int.Parse(parts1[1]);

            string[] parts2 = coordinates2.Split(':');
            int row2 = int.Parse(parts2[0]);
            int column2 = int.Parse(parts2[1]);

            if (Cards[row1][column1].ImagePath == Cards[row2][column2].ImagePath)
            {
                Console.WriteLine("Paire trouvée !");
                return true;
            }
            else
            {
                Console.WriteLine("Ce n'est pas une paire.");
                return false;
            }
        }

        public void PairedCard(string coordinates)
        {
            string[] parts = coordinates.Split(':');
            int row = int.Parse(parts[0]);
            int column = int.Parse(parts[1]);

            Cards[row][column].Paired();
        }

        public bool AllFound()
        {
            for (int i = 0; i < AllCards.Count; i++)
            {
                if (AllCards[i].Status != Carte.State.Trouvée)
                {
                    return false;
                }
            }
            return true;
        }
    }
}