using System;

namespace Memory
{
    public class Carte
    {
        public int Id { get; set; }
        public int Value { get; set; }
        public enum State { Cachée, Révélée, Trouvée }
        public State Status { get; set; }

        public Carte(int id, int value)
        {
            Id = id;
            Value = value;
            Status = State.Cachée;
        }

        public void Reveal()
        {
            Status = State.Révélée;
        }

        public void Hide()
        {
            Status = State.Cachée;
        }

        public void Paired()
        {
            Status = State.Trouvée;
        }
    }
}