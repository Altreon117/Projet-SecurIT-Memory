using System;
using System.Collections.Generic;
using System.Windows.Forms;
using System.Drawing;
using Memory;

namespace projet_memory
{
    public class MemoryForm : Form
    {
        private Liste game;
        private Button[,] cardButtons;
        private Label scoreLabel;
        private Label statusLabel;
        private Button resetButton;
        private int moves = 0;
        private int pairs = 0;
        private int selectedCount = 0;
        private string firstCoordinate = "";
        private Button firstButton = null;
        private Button secondButton = null;
        private bool isCheckingPair = false;
        private int numberOfPairs = 8;

        public MemoryForm()
        {
            InitializeComponent();
            StartNewGame();
        }

        private void InitializeComponent()
        {
            this.Text = "Memory Game";
            this.Width = 800;
            this.Height = 900;
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = Color.LightGray;

            // Panel pour les boutons
            Panel gamePanel = new Panel();
            gamePanel.Location = new Point(50, 80);
            gamePanel.AutoSize = false;
            gamePanel.Width = 700;
            gamePanel.Height = 700;
            gamePanel.BackColor = Color.DarkGray;
            this.Controls.Add(gamePanel);

            // Labels
            scoreLabel = new Label();
            scoreLabel.Text = "Déplacements: 0 | Paires trouvées: 0 / " + numberOfPairs;
            scoreLabel.Location = new Point(50, 20);
            scoreLabel.AutoSize = true;
            scoreLabel.Font = new Font("Arial", 12, FontStyle.Bold);
            this.Controls.Add(scoreLabel);

            statusLabel = new Label();
            statusLabel.Text = "Sélectionnez deux cartes";
            statusLabel.Location = new Point(50, 50);
            statusLabel.AutoSize = true;
            statusLabel.Font = new Font("Arial", 10);
            this.Controls.Add(statusLabel);

            // Bouton Reset
            resetButton = new Button();
            resetButton.Text = "Nouvelle partie";
            resetButton.Location = new Point(600, 20);
            resetButton.Width = 150;
            resetButton.Height = 30;
            resetButton.Click += ResetButton_Click;
            this.Controls.Add(resetButton);

            CreateCardButtons(gamePanel);
        }

        private void StartNewGame()
        {
            game = new Liste(numberOfPairs);
            cardButtons = new Button[game.Rows, game.Columns];
            moves = 0;
            pairs = 0;
            selectedCount = 0;
            firstCoordinate = "";
            firstButton = null;
            secondButton = null;
            isCheckingPair = false;

            // Clear the panel
            if (this.Controls.Count > 0)
            {
                Control gamePanel = null;
                foreach (Control c in this.Controls)
                {
                    if (c is Panel && c.Name != "")
                    {
                        gamePanel = c;
                        break;
                    }
                }

                if (gamePanel == null)
                {
                    foreach (Control c in this.Controls)
                    {
                        if (c is Panel)
                        {
                            gamePanel = c;
                            break;
                        }
                    }
                }

                if (gamePanel != null)
                {
                    gamePanel.Controls.Clear();
                    CreateCardButtons(gamePanel);
                }
            }

            UpdateScore();
        }

        private void CreateCardButtons(Panel gamePanel)
        {
            int buttonSize = 80;
            int spacing = 10;

            for (int i = 0; i < game.Rows; i++)
            {
                for (int j = 0; j < game.Columns; j++)
                {
                    Button btn = new Button();
                    btn.Width = buttonSize;
                    btn.Height = buttonSize;
                    btn.Left = j * (buttonSize + spacing) + spacing;
                    btn.Top = i * (buttonSize + spacing) + spacing;
                    btn.Text = "?";
                    btn.Font = new Font("Arial", 20, FontStyle.Bold);
                    btn.BackColor = Color.SteelBlue;
                    btn.ForeColor = Color.White;
                    btn.Tag = $"{i}:{j}";
                    btn.Click += CardButton_Click;

                    cardButtons[i, j] = btn;
                    gamePanel.Controls.Add(btn);
                }
            }
        }

        private void CardButton_Click(object sender, EventArgs e)
        {
            if (isCheckingPair) return;

            Button btn = (Button)sender;
            string coordinates = (string)btn.Tag;
            string[] parts = coordinates.Split(':');
            int row = int.Parse(parts[0]);
            int col = int.Parse(parts[1]);

            Carte card = game.Cards[row][col];

            if (card.Status == Carte.State.Trouvée) return;
            if (card.Status == Carte.State.Révélée) return;

            card.Reveal();
            btn.Text = card.Value.ToString();
            btn.Enabled = false;

            selectedCount++;

            if (selectedCount == 1)
            {
                firstCoordinate = coordinates;
                firstButton = btn;
                statusLabel.Text = "Sélectionnez la deuxième carte";
            }
            else if (selectedCount == 2)
            {
                moves++;
                isCheckingPair = true;

                string secondCoordinate = coordinates;
                secondButton = btn;

                // Check if they match
                if (game.IsPair(firstCoordinate, secondCoordinate))
                {
                    game.PairedCard(firstCoordinate);
                    game.PairedCard(secondCoordinate);
                    pairs++;

                    firstButton.BackColor = Color.LimeGreen;
                    secondButton.BackColor = Color.LimeGreen;
                    firstButton.Enabled = true;
                    secondButton.Enabled = true;

                    statusLabel.Text = "Paire trouvée!";

                    if (pairs == numberOfPairs)
                    {
                        statusLabel.Text = $"Bravo! Vous avez gagné en {moves} mouvements!";
                        resetButton.Enabled = true;
                    }
                }
                else
                {
                    statusLabel.Text = "Ce n'est pas une paire. Réessayez!";

                    // Hide the cards after a delay
                    Timer hideTimer = new Timer();
                    hideTimer.Interval = 1000;
                    hideTimer.Tick += (s, args) =>
                    {
                        game.HideCard(firstCoordinate);
                        game.HideCard(secondCoordinate);

                        firstButton.Text = "?";
                        firstButton.BackColor = Color.SteelBlue;
                        firstButton.Enabled = true;

                        secondButton.Text = "?";
                        secondButton.BackColor = Color.SteelBlue;
                        secondButton.Enabled = true;

                        hideTimer.Stop();
                        hideTimer.Dispose();

                        selectedCount = 0;
                        firstCoordinate = "";
                        firstButton = null;
                        secondButton = null;
                        isCheckingPair = false;

                        statusLabel.Text = "Sélectionnez deux cartes";
                    };
                    hideTimer.Start();

                    selectedCount = 0;
                    firstCoordinate = "";
                    firstButton = null;
                    secondButton = null;
                    isCheckingPair = false;
                }

                UpdateScore();
            }
        }

        private void ResetButton_Click(object sender, EventArgs e)
        {
            StartNewGame();
        }

        private void UpdateScore()
        {
            scoreLabel.Text = $"Déplacements: {moves} | Paires trouvées: {pairs} / {numberOfPairs}";
        }

        protected override void OnLoad(EventArgs e)
        {
            base.OnLoad(e);
            UpdateScore();
        }
    }

    static class Program
    {
        [STAThread]
        static void Main()
        {
            Application.EnableVisualStyles();
            Application.Run(new MemoryForm());
        }
    }
}
